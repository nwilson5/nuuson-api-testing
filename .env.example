# Copy to .env and fill in values for local development.
# In production these are injected by Vault via CI/CD.

# From secret/shared/gemini — required for /v1/testing/ask
GEMINI_API_KEY=your-gemini-api-key-here

# Set by CI at deploy time — not needed for local dev
# IMAGE_TAG=
# TRAEFIK_HOST=testing-internal.nuuson.dev
# TRAEFIK_ROUTER=nuuson-api-testing
